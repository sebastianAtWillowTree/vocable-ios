    "listening_mode.empty_state.vocableAPIFailure.message" : {
      "comment" : "Listen mode error state message for when the vocable API fails",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى التحقق من اتصالك بالإنترنت والمحاولة مرة أخرى في وقت لاحق."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tjek venligst din internetforbindelse og prøv igen senere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte überprüfen Sie Ihre Internetverbindung und versuchen Sie es später erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please check your internet connection and try again later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, comprueba tu conexión a Internet e intenta nuevamente más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez vérifier votre connexion internet et réessayer plus tard."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कृपया अपने इंटरनेट संबंध की जांच करें और बाद में पुनः प्रयास करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controlla la tua connessione internet e riprova più tardi."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인터넷 연결을 확인하고 나중에 다시 시도해주세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пожалуйста, проверьте ваше интернет-соединение и попробуйте снова позже."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vui lòng kiểm tra kết nối internet của bạn và thử lại sau."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请检查您的互联网连接并稍后再试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請檢查您的網路連接並稍後再試。"
          }
        }
      }
    },
