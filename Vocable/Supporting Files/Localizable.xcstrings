          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने सबसे हाल ही में उपयोग किए गए वाक्यांशों को यहां देखने के लिए वोकेबल का उपयोग करना प्रारंभ करें।"
